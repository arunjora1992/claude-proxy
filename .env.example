# Copy this to .env and adjust as needed.
# The proxy forwards your API key from Claude Code requests —
# you do NOT need to set ANTHROPIC_API_KEY here.

# Port the proxy listens on (must match docker-compose.yml ports mapping)
PROXY_PORT=8082

# Response cache (exact-match, 100% token savings on repeated requests)
CACHE_ENABLED=true
CACHE_MAXSIZE=1000
CACHE_TTL=3600

# Prompt caching (auto cache_control injection, up to 90% savings)
PROMPT_CACHE_ENABLED=true
PROMPT_CACHE_MIN_TOKENS=1024

# Model routing — DISABLED by default for Claude Code compatibility.
# Enable only if you are NOT routing Claude Code traffic.
ROUTING_ENABLED=false
HAIKU_THRESHOLD=2000
SONNET_THRESHOLD=8000

# Context trimming — DISABLED by default for Claude Code compatibility.
CONTEXT_TRIM_ENABLED=false
CONTEXT_MAX_TURNS=20

# Batch API queue (50% discount for non-real-time traffic)
BATCH_ENABLED=false
